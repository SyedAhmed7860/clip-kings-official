/**
 * Smart King Assistant - AI-Free Logic Tree Chatbot
 * Optimized for Booksy Conversions & Human-like interactions
 */

class SmartKingAssistant {
    constructor() {
        this.isOpen = false;
        this.isTyping = false;
        
        // Chatbot ka dimag (Knowledge Base)
        this.knowledgeBase = this.initKnowledgeBase();
        
        this.initDOM();
        this.attachEvents();
        this.bindTriggers();
    }

    // Yahan hum chatbot ko sikhayenge ki kis word par kya bolna hai
    initKnowledgeBase() {
        return [
            {
                intent: "greeting",
                keywords: ["hi", "hello", "hey", "sup", "yo", "namaste", "hi there", "morning", "evening"],
                responses: [
                    "Hey there! Clip Kings me aapka swagat hai. Main aapki kya help kar sakta hu?",
                    "Hello boss! Welcome to the shop. Aaj kya service chahiye aapko?",
                    "Hey! Clip Kings assistant here. Let me know what you need!"
                ],
                buttons: [{ text: "Book Now", action: "book_now", primary: true }, { text: "Services", action: "view_services" }]
            },
            {
                intent: "booking",
                keywords: ["book", "appointment", "schedule", "reserve", "slot", "booking", "aana hai", "time chahiye"],
                responses: [
                    "Great choice! Humari sabhi bookings Booksy ke through hoti hain taaki aapko perfect time mil sake.",
                    "Ready for a fresh cut? Aap apna spot niche diye gaye link se reserve kar sakte hain.",
                    "Let's get you lined up! Aap humari Booksy profile se directly time select kar sakte hain."
                ],
                buttons: [{ text: "Continue to Booksy", action: "link_booksy", primary: true }]
            },
            {
                intent: "pricing",
                keywords: ["price", "cost", "much", "rate", "kitne", "paise", "charges", "expensive", "cheap"],
                responses: [
                    "Humari standard pricing $25 (Classic Haircut) se start hoti hai. Skin Fade $30 ka hai, aur full Haircut + Beard line up $45 ka hai.",
                    "Pricing ekdum straightforward hai boss. $25 for normal cuts, $30 for fades, and $45 with beard. Happy hours me 20% off bhi milta hai!",
                    "Standard cuts are $25-$30. Agar aapko detailed pricing dekhni hai toh main menu bhej deta hu."
                ],
                buttons: [{ text: "Book Now", action: "book_now", primary: true }, { text: "Full Menu", action: "link_services" }]
            },
            {
                intent: "location",
                keywords: ["where", "location", "address", "map", "kaha", "kahan", "shop", "directions", "kidhar"],
                responses: [
                    "Humari shop 370 Steeles Ave W #105, Thornhill (ON) me located hai. VIP parking free hai shop ke theek samne!",
                    "You can find us at 370 Steeles Ave W, Thornhill. Aate waqt parking ki tension mat lena, it's on us."
                ],
                buttons: [{ text: "Get Directions", action: "get_directions", primary: true }]
            },
            {
                intent: "hours",
                keywords: ["hours", "open", "close", "time", "kab", "khula", "baje", "timing"],
                responses: [
                    "Hum Monday se Friday 9:00 AM se 8:00 PM tak open rehte hain. Saturday 9 AM - 6 PM, aur Sunday 10 AM - 4 PM.",
                    "Shop timings: Mon-Fri (9am-8pm), Sat (9am-6pm), and Sun (10am-4pm). Better to book in advance!"
                ],
                buttons: [{ text: "Book Now", action: "book_now", primary: true }]
            },
            {
                intent: "walkin",
                keywords: ["walk", "walk-in", "wait", "bina appointment", "direct", "walkin"],
                responses: [
                    "Hum walk-ins bilkul accept karte hain! But chairs jaldi full ho jati hain, isliye hum hamesha pre-booking recommend karte hain.",
                    "Walk-ins are welcome! Lakin agar aapko wait nahi karna toh Booksy par slot reserve kar lena better rahega."
                ],
                buttons: [{ text: "Check Availability (Book)", action: "book_now", primary: true }]
            },
            {
                intent: "beard",
                keywords: ["beard", "trim", "shave", "daadhi", "dadhi", "line up", "lineup"],
                responses: [
                    "Beard services humari specialty hai! Beard Trim $15 ka hai, aur Luxury Hot Towel Shave $35 ka padega.",
                    "We'll get that beard looking sharp. We do shaping, trimming, and traditional hot towel shaves."
                ],
                buttons: [{ text: "Book Beard Service", action: "book_now", primary: true }]
            },
            {
                intent: "kids",
                keywords: ["kid", "boy", "child", "children", "bache", "bacha", "son"],
                responses: [
                    "Yes, hum kids haircuts bhi karte hain! Under 12 years ke liye price usually $20 hai.",
                    "Bring the little king in! Kids cuts are $20 and our barbers are great with them."
                ],
                buttons: [{ text: "Book Kids Cut", action: "book_now", primary: true }]
            },
            {
                intent: "contact",
                keywords: ["contact", "phone", "call", "number", "reach", "baat"],
                responses: [
                    "Aap humein directly (905) 707-1969 par call kar sakte hain.",
                    "Need to speak with someone? Shop ka number (905) 707-1969 hai."
                ],
                buttons: [{ text: "Call Now", action: "call_shop", primary: true }]
            }
        ];
    }

    initDOM() {
        // UI me CSS aur Input box add kar rahe hain
        const style = document.createElement('style');
        style.innerHTML = `
            #chatbot-widget { position: fixed; bottom: 30px; right: 30px; z-index: 9999; font-family: var(--font-body, sans-serif); }
            .chatbot-bubble { width: 60px; height: 60px; background: var(--color-gold, #D4AF37); border-radius: 50%; display: flex; justify-content: center; align-items: center; cursor: pointer; box-shadow: 0 5px 15px rgba(0,0,0,0.3); transition: transform 0.3s; }
            .chatbot-bubble:hover { transform: scale(1.1); }
            .chatbot-bubble svg { width: 30px; height: 30px; fill: #111; }
            .chatbot-container { position: absolute; bottom: 80px; right: 0; width: 350px; background: #111; border: 1px solid rgba(212, 175, 55, 0.2); border-radius: 15px; overflow: hidden; display: none; flex-direction: column; box-shadow: 0 10px 30px rgba(0,0,0,0.5); opacity: 0; transform: translateY(20px); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
            .chatbot-container.active { display: flex; opacity: 1; transform: translateY(0); }
            .chatbot-header { background: #1a1a1a; padding: 15px; border-bottom: 1px solid rgba(212, 175, 55, 0.2); display: flex; justify-content: space-between; align-items: center; }
            .chatbot-header h4 { margin: 0; color: var(--color-gold, #D4AF37); font-size: 16px; display: flex; align-items: center; gap: 8px; }
            .chatbot-header-icon { width: 10px; height: 10px; background: #2ecc71; border-radius: 50%; display: inline-block; box-shadow: 0 0 5px #2ecc71; }
            .chatbot-close { background: none; border: none; color: #fff; font-size: 24px; cursor: pointer; line-height: 1; }
            .chatbot-body { padding: 15px; height: 350px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; scroll-behavior: smooth; }
            .chatbot-body::-webkit-scrollbar { width: 5px; }
            .chatbot-body::-webkit-scrollbar-thumb { background: rgba(212, 175, 55, 0.5); border-radius: 5px; }
            
            /* Input Area CSS */
            .chatbot-input-area { padding: 10px 15px; background: #1a1a1a; border-top: 1px solid rgba(212, 175, 55, 0.2); display: flex; gap: 10px; }
            .chatbot-input { flex: 1; background: #222; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 10px 15px; color: #fff; outline: none; transition: border-color 0.3s; }
            .chatbot-input:focus { border-color: var(--color-gold, #D4AF37); }
            .chatbot-send-btn { background: var(--color-gold, #D4AF37); color: #111; border: none; border-radius: 50%; width: 40px; height: 40px; display: flex; justify-content: center; align-items: center; cursor: pointer; transition: transform 0.2s; }
            .chatbot-send-btn:hover { transform: scale(1.05); }
            .chatbot-send-btn svg { width: 18px; height: 18px; fill: #111; margin-left: 2px; }

            /* Messages CSS */
            .chat-msg { max-width: 80%; padding: 10px 14px; border-radius: 15px; font-size: 14px; line-height: 1.4; animation: popIn 0.3s ease; }
            .chat-msg.bot { background: #222; color: #eee; align-self: flex-start; border-bottom-left-radius: 2px; }
            .chat-msg.user { background: var(--color-gold, #D4AF37); color: #111; align-self: flex-end; border-bottom-right-radius: 2px; }
            .chat-buttons { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 5px; animation: popIn 0.4s ease; }
            .chat-btn { background: transparent; border: 1px solid var(--color-gold, #D4AF37); color: var(--color-gold, #D4AF37); padding: 6px 12px; border-radius: 20px; font-size: 12px; cursor: pointer; transition: all 0.2s; }
            .chat-btn:hover { background: rgba(212, 175, 55, 0.1); }
            .chat-btn.primary { background: var(--color-gold, #D4AF37); color: #111; }
            .chat-btn.primary:hover { background: #b8962e; }
            
            .typing-indicator { align-self: flex-start; background: #222; padding: 12px 16px; border-radius: 15px; display: flex; gap: 5px; border-bottom-left-radius: 2px; margin-bottom: 10px; }
            .typing-dot { width: 6px; height: 6px; background: rgba(255,255,255,0.5); border-radius: 50%; animation: typing 1.4s infinite ease-in-out both; }
            .typing-dot:nth-child(1) { animation-delay: -0.32s; }
            .typing-dot:nth-child(2) { animation-delay: -0.16s; }
            
            @keyframes popIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
            @keyframes typing { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
            @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.7); } 70% { box-shadow: 0 0 0 15px rgba(212, 175, 55, 0); } 100% { box-shadow: 0 0 0 0 rgba(212, 175, 55, 0); } }
            
            @media (max-width: 480px) {
                .chatbot-container { width: calc(100vw - 40px); right: 20px; bottom: 90px; }
            }
        `;
        document.head.appendChild(style);

        const widgetHTML = `
            <div id="chatbot-widget">
                <div class="chatbot-bubble magnetic" id="chat-bubble">
                    <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
                </div>
                <div class="chatbot-container" id="chat-container">
                    <div class="chatbot-header">
                        <h4><span class="chatbot-header-icon"></span> King Assistant</h4>
                        <button class="chatbot-close" id="chat-close">&times;</button>
                    </div>
                    <div class="chatbot-body" id="chat-body"></div>
                    <div class="chatbot-input-area">
                        <input type="text" id="chat-input" class="chatbot-input" placeholder="Type your question..." autocomplete="off">
                        <button id="chat-send" class="chatbot-send-btn">
                            <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
                        </button>
                    </div>
                </div>
            </div>
        `;
        document.body.insertAdjacentHTML('beforeend', widgetHTML);

        this.bubble = document.getElementById('chat-bubble');
        this.container = document.getElementById('chat-container');
        this.closeBtn = document.getElementById('chat-close');
        this.body = document.getElementById('chat-body');
        this.input = document.getElementById('chat-input');
        this.sendBtn = document.getElementById('chat-send');
    }

    attachEvents() {
        this.bubble.addEventListener('click', () => this.toggleChat());
        this.closeBtn.addEventListener('click', () => this.toggleChat());
        
        // Handle Action Buttons
        this.body.addEventListener('click', (e) => {
            if (e.target.classList.contains('chat-btn') && e.target.dataset.action) {
                this.handleAction(e.target.dataset.action, e.target.textContent);
            }
        });

        // Handle Text Input
        this.sendBtn.addEventListener('click', () => this.handleUserInput());
        this.input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') this.handleUserInput();
        });
    }

    bindTriggers() {
        setTimeout(() => {
            if(!sessionStorage.getItem('chatPrompted')) {
                this.bubble.style.animation = "pulse 2s infinite";
                sessionStorage.setItem('chatPrompted', 'true');
            }
        }, 8000); 
    }

    toggleChat() {
        this.isOpen = !this.isOpen;
        if (this.isOpen) {
            this.container.classList.add('active');
            this.bubble.style.animation = "none";
            if (this.body.children.length === 0) {
                this.startWelcomeFlow();
            }
            setTimeout(() => this.input.focus(), 300);
        } else {
            this.container.classList.remove('active');
        }
    }

    scrollBottom() {
        this.body.scrollTop = this.body.scrollHeight;
    }

    showTyping() {
        this.isTyping = true;
        const id = 'typing-' + Date.now();
        const html = `
            <div class="typing-indicator" id="${id}">
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
            </div>
        `;
        this.body.insertAdjacentHTML('beforeend', html);
        this.scrollBottom();
        return id;
    }

    removeTyping(id) {
        this.isTyping = false;
        const el = document.getElementById(id);
        if (el) el.remove();
    }

    addUserMessage(text) {
        const html = `<div class="chat-msg user">${text}</div>`;
        this.body.insertAdjacentHTML('beforeend', html);
        this.scrollBottom();
    }

    addBotMessage(text) {
        const html = `<div class="chat-msg bot">${text}</div>`;
        this.body.insertAdjacentHTML('beforeend', html);
        this.scrollBottom();
    }

    addButtons(buttons) {
        if(!buttons || buttons.length === 0) return;
        const btnHtml = buttons.map(b => `
            <button class="chat-btn ${b.primary ? 'primary' : ''}" data-action="${b.action}">
                ${b.text}
            </button>
        `).join('');
        const html = `<div class="chat-buttons">${btnHtml}</div>`;
        this.body.insertAdjacentHTML('beforeend', html);
        this.scrollBottom();
    }

    hideOldButtons() {
        const currentButtons = this.body.querySelectorAll('.chat-buttons');
        if(currentButtons.length > 0) {
            currentButtons[currentButtons.length-1].style.opacity = '0.5';
            currentButtons[currentButtons.length-1].style.pointerEvents = 'none';
        }
    }

    async processBotResponse(text, buttons = [], delay = 1000) {
        const typeId = this.showTyping();
        // Dynamic delay based on text length to feel more human
        const dynamicDelay = Math.min(Math.max(text.length * 20, 800), 2500); 
        await new Promise(r => setTimeout(r, dynamicDelay));
        
        this.removeTyping(typeId);
        this.addBotMessage(text);
        if(buttons.length > 0) {
            setTimeout(() => this.addButtons(buttons), 200);
        }
    }

    // --- SMART LOGIC ---

    handleUserInput() {
        if(this.isTyping) return;
        
        const rawText = this.input.value.trim();
        if(rawText === '') return;
        
        this.input.value = '';
        this.addUserMessage(rawText);
        this.hideOldButtons();
        
        this.analyzeAndRespond(rawText);
    }

    analyzeAndRespond(userInput) {
        // Text clean up
        const text = userInput.toLowerCase().replace(/[^\w\s]/gi, '');
        const words = text.split(' ');
        
        let bestMatch = null;
        let maxScore = 0;

        // Scoring algorithm: intent find kar rahe hain
        this.knowledgeBase.forEach(intentData => {
            let score = 0;
            intentData.keywords.forEach(kw => {
                if(text.includes(kw)) score++;
            });
            if(score > maxScore) {
                maxScore = score;
                bestMatch = intentData;
            }
        });

        // Agar match mila
        if (bestMatch && maxScore > 0) {
            // Random human-like variation pick karo
            const randomResponse = bestMatch.responses[Math.floor(Math.random() * bestMatch.responses.length)];
            this.processBotResponse(randomResponse, bestMatch.buttons);
        } else {
            // Agar bot nahi samajh paya (Fallback Logic)
            const fallbackResponses = [
                "I'm sorry, main thoda confused hu. Aap in options me se choose kar sakte hain:",
                "Let me get a human for complex queries! Till then, check these out:",
                "Hmm, I didn't quite catch that. But here are some quick links that might help:"
            ];
            const fallbackText = fallbackResponses[Math.floor(Math.random() * fallbackResponses.length)];
            
            this.processBotResponse(fallbackText, [
                { text: "Book Appointment", action: "link_booksy", primary: true },
                { text: "Services & Prices", action: "link_services" },
                { text: "Call Shop", action: "call_shop" }
            ], 1200);
        }
    }

    // --- BUTTON ACTIONS ---

    handleAction(action, text) {
        this.addUserMessage(text);
        this.hideOldButtons();

        switch (action) {
            case 'book_now':
                this.processBotResponse("Great! Hum bookings directly Booksy par handle karte hain. Click below to secure your spot.", [
                    { text: "Continue to Booksy", action: "link_booksy", primary: true }
                ]);
                break;
            case 'view_services':
                this.processBotResponse("Humare paas sab kuch hai: Fades, Beard Trims, aur Hot Towel Shaves. Full list dekhni hai?", [
                    { text: "View Full Menu", action: "link_services", primary: true },
                    { text: "Pricing batao", action: "trigger_pricing" }
                ]);
                break;
            case 'trigger_pricing':
                this.analyzeAndRespond("price"); // Trigger AI logic internally
                break;
            case 'contact_us':
                this.analyzeAndRespond("contact");
                break;
            case 'link_booksy':
                window.open('https://booksy.com/en-ca/24439_clip-kings-barber-shop_barbershop_990795_thornhill', '_blank');
                this.processBotResponse("Main naye tab me Booksy open kar raha hu. See you soon!");
                break;
            case 'link_services':
                window.location.href = 'services.html';
                break;
            case 'call_shop':
                window.location.href = 'tel:+19057071969';
                break;
            case 'get_directions':
                window.open('https://www.google.com/maps/place/Clip+Kings+Barber+Shop/@43.7960533,-79.4361299,795m', '_blank');
                break;
        }
    }

    startWelcomeFlow() {
        const timeHour = new Date().getHours();
        let greeting = "Hello!";
        if(timeHour < 12) greeting = "Good Morning!";
        else if(timeHour < 18) greeting = "Good Afternoon!";
        else greeting = "Good Evening!";

        this.processBotResponse(`${greeting} Welcome to Clip Kings. Aap yahan freely type karke kuch bhi puch sakte hain, ya quick buttons use kar sakte hain.`, [
            { text: "Book an Appointment", action: "book_now", primary: true },
            { text: "View Services", action: "view_services" },
            { text: "Where are you located?", action: "contact_us" }
        ]);
    }
}

// Ensure init on load
if (document.readyState === 'complete' || document.readyState === 'interactive') {
    window.kingAssistant = new SmartKingAssistant();
} else {
    document.addEventListener('DOMContentLoaded', () => {
        window.kingAssistant = new SmartKingAssistant();
    });
}